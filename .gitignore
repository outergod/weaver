/.agent/
/.direnv/

# MemPalace per-project files (issue #185)
mempalace.yaml
entities.json

# Speckit / Claude Code plugin artefacts. These directories contain
# tracked files (plugin SKILL.md templates, bash scripts, settings),
# but they are tooling surface that `mempalace mine` should never
# index — it has no mempalace-specific exclude mechanism, only
# .gitignore. Listing them here keeps future re-mines from polluting
# the weaver wing with plugin internals. Already-tracked files stay
# tracked; `git commit -a` still stages their modifications.
/.claude/
/.specify/

# Rust build outputs
/target/
**/*.rs.bk

# Bus socket files (per Hello-fact slice 001)
*.sock

# IDEs
/.idea/
/.vscode/

# Note: Cargo.lock is intentionally NOT gitignored.
# Workspace Cargo.lock MUST be tracked per L2 constitution P19
# (reproducible builds). Cargo's defaults are correct for binary
# crates; this clause is for defensive clarity (per Hello-fact tasks T003).
